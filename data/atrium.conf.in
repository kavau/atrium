# /etc/atrium.conf — atrium display manager configuration
# Lines starting with '#' are comments.  Unknown keys are ignored with a
# warning in the journal.

# Compositor to launch on each seat after successful authentication.
# Executed via the user's login shell, so PATH is available.
compositor = sway

# Desktop environment identifier passed to logind's CreateSession and set as
# XDG_CURRENT_DESKTOP and XDG_SESSION_DESKTOP in the session environment.
desktop = sway

# Seconds to wait before restarting the greeter after compositor exit.
restart-delay = 2

# Greeter command.  Must honour the CREDENTIALS_FD and RESULT_FD environment
# variables set by the daemon.  Executed via /bin/sh.
#
# The '-s' flag tells cage to allow VT switching (Ctrl+Alt+F1/F2/...) from
# the greeter, which is useful for reaching a recovery TTY before login.
# Drop it for a kiosk-style lockdown that traps the user at the greeter.
greeter = /usr/bin/cage -s -- @greeter_bin@

# Seconds to wait after startup before enumerating seats.  Gives logind time
# to finish processing udev seat events on early boot.  Increase if greeters
# appear on the wrong seats or seats are missed at startup.
seat-enum-delay = 5

# Seats to ignore during enumeration.  Repeat for multiple seats.
# Useful for seats with no connected display that would crash-loop the greeter.
#
# Example:
#   ignore-seat = seat2

# Users that can log in without a password.  Repeat for multiple users.
# The greeter skips the password screen; the daemon skips PAM authentication.
# Omit to require a password for all users.
#
# Warning: bypasses PAM entirely — resource limits, account expiry, access
# restrictions, and audit logging are all skipped.  In a future version, the
# greeter will check membership of a 'nopasswd' group instead, and a PAM rule
# (e.g. pam_succeed_if.so) will skip password verification for group members.
#
# Example:
#   passwordless-user = kiosk
